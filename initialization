#include <Arduino.h>
#include "driver/twai.h"
#include "driver/gpio.h" 

#define CAN_TX_PIN 5  // Physical pin D5
#define CAN_RX_PIN 4  // Physical pin D4

unsigned long previousMillis = 0;
const long broadcastInterval = 100; 

void sendGatewayWakeFrame();

void setup() {
    Serial.begin(115200);
    while(!Serial) { delay(10); } 
    
    Serial.println("=========================================");
    Serial.println("Audi B8.5 S5 Cluster Simulator (Software Bias)");
    Serial.println("=========================================");

    // Activate internal ESP32 pull-ups to stabilize the un-terminated bus lines
    pinMode(CAN_TX_PIN, INPUT_PULLUP);
    pinMode(CAN_RX_PIN, INPUT_PULLUP);
    delay(10);

    // Initialize Network parameters
    twai_general_config_t general_config = TWAI_GENERAL_CONFIG_DEFAULT((gpio_num_t)CAN_TX_PIN, (gpio_num_t)CAN_RX_PIN, TWAI_MODE_NORMAL);
    twai_timing_config_t timing_config = TWAI_TIMING_CONFIG_500KBITS(); 
    twai_filter_config_t filter_config = TWAI_FILTER_CONFIG_ACCEPT_ALL();

    if (twai_driver_install(&general_config, &timing_config, &filter_config) != ESP_OK) {
        Serial.println("Status: Internal driver failed to install.");
        return;
    }

    if (twai_start() != ESP_OK) {
        Serial.println("Status: Internal driver failed to start.");
        return;
    }

    Serial.println("Status: Transmitting 500kbps gateway wake sequence...");
}

void loop() {
    unsigned long currentMillis = millis();
    
    if (currentMillis - previousMillis >= broadcastInterval) {
        previousMillis = currentMillis;
        sendGatewayWakeFrame();
    }
}

void sendGatewayWakeFrame() {
    twai_message_t tx_frame;
    
    tx_frame.identifier = 0x3C0;       
    tx_frame.extd = 0;                 
    tx_frame.data_length_code = 8;     
    
    tx_frame.data[0] = 0x03; 
    tx_frame.data[1] = 0x01; 
    tx_frame.data[2] = 0x00; 
    tx_frame.data[3] = 0x00; 
    tx_frame.data[4] = 0x00; 
    tx_frame.data[5] = 0x00; 
    tx_frame.data[6] = 0x00; 
    tx_frame.data[7] = 0x00;

    if (twai_transmit(&tx_frame, pdMS_TO_TICKS(10)) != ESP_OK) {
        // Reduced serial spam for un-terminated testing
        static unsigned long lastAlert = 0;
        if (millis() - lastAlert > 2000) {
            Serial.println("Bus Notice: Signal reflecting (Missing hardware resistor). Retrying...");
            lastAlert = millis();
        }
    }
}
