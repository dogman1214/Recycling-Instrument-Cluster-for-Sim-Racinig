#include "driver/twai.h"

#define TX_PIN GPIO_NUM_4
#define RX_PIN GPIO_NUM_5

void setup() {
    Serial.begin(115200);
    delay(2000);
    Serial.println("=========================================");
    Serial.println("Initializing Audi B8.5 - 500K High Speed");
    Serial.println("=========================================");
    
    // Switch back to 500 kbps 
    twai_general_config_t g_config = TWAI_GENERAL_CONFIG_DEFAULT(TX_PIN, RX_PIN, TWAI_MODE_NORMAL);
    twai_timing_config_t t_config = TWAI_TIMING_CONFIG_500KBITS(); 
    twai_filter_config_t f_config = TWAI_FILTER_CONFIG_ACCEPT_ALL();

    if (twai_driver_install(&g_config, &t_config, &f_config) == ESP_OK) {
        Serial.println("[OK] TWAI Driver Installed.");
    } else {
        Serial.println("[FAIL] Driver installation failed.");
        return;
    }

    if (twai_start() == ESP_OK) {
        Serial.println("[OK] Driver running at 500kbps.");
    } else {
        Serial.println("[FAIL] Failed to start driver.");
        return;
    }
}

void loop() {
    twai_message_t msg_ignition;
    msg_ignition.identifier = 0x271;       
    msg_ignition.extd = 0;
    msg_ignition.rtr = 0;
    msg_ignition.data_length_code = 8;
    msg_ignition.data[0] = 0x01;           
    msg_ignition.data[1] = 0x0B;           
    for(int i=2; i<8; i++) msg_ignition.data[i] = 0x00;

    // Transmit ignition wake-up
    twai_transmit(&msg_ignition, pdMS_TO_TICKS(5));
    delay(5); 

    twai_message_t msg_rpm;
    msg_rpm.identifier = 0x105;            
    msg_rpm.extd = 0;
    msg_rpm.rtr = 0;
    msg_rpm.data_length_code = 8;
    msg_rpm.data[0] = 0x00; 
    msg_rpm.data[1] = 0x00; 
    msg_rpm.data[2] = 0xE0;                // 3000 RPM
    msg_rpm.data[3] = 0x2E;                
    for(int i=4; i<8; i++) msg_rpm.data[i] = 0x00; 

    // Transmit RPM metrics
    if (twai_transmit(&msg_rpm, pdMS_TO_TICKS(5)) == ESP_OK) {
        Serial.println("[TX] Frames acknowledged at 500kbps.");
    } else {
        Serial.println("[WARN] No ACK received. Check wire polarity (try swapping CANH/CANL).");
    }

    delay(20); 
}
